generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  username      String     @unique
  displayName   String     @default("Challenger")
  password      String?
  points        Int        @default(1000)
  role          String     @default("USER")
  nameColor     String     @default("#ffffff")
  winStreak     Int        @default(0)
  fdShields     Int        @default(0)
  fatalCounters Int        @default(0)
  lastWelfareAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  bets          Bet[]
  purchases     Purchase[]
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  item      String
  cost      Int
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Tournament {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("GROUP_STAGE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  matches   Match[]
}

model Match {
  id                String      @id @default(cuid())
  playerA           String
  playerB           String
  charA             String?
  charB             String?
  status            String      @default("OPEN")
  winner            String?
  tournamentId      String?
  stageType         String?
  groupId           String?
  roundName         String?
  nextWinnerMatchId String?
  nextLoserMatchId  String?
  poolInjectA       Int         @default(0)
  poolInjectB       Int         @default(0)
  scoreA            Int?
  scoreB            Int?
  lockAt            DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  groupName         String?
  bets              Bet[]
  tournament        Tournament? @relation(fields: [tournamentId], references: [id])
}

model Bet {
  id             String   @id @default(cuid())
  userId         String
  matchId        String
  amount         Int
  choice         String
  comment        String?
  createdAt      DateTime @default(now())
  predictedScore String?
  usedItem       String?
  match          Match    @relation(fields: [matchId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  used      Boolean  @default(false)
  usedBy    String?
  createdAt DateTime @default(now())
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String
  details   String
  createdAt DateTime @default(now())
}

model ActionLog {
  id        String   @id @default(cuid())
  actionType String   // e.g., "BET", "SHOP", "ADMIN_SETTLE"
  userId    String?  // Optional, if tied to a user
  details   String   // The content to display
  createdAt DateTime @default(now())
}
