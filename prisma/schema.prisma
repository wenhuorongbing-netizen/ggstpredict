generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(cuid())
  username      String             @unique
  displayName   String             @default("Challenger")
  password      String?
  points        Int                @default(1000)
  role          String             @default("USER")
  nameColor     String             @default("#ffffff")
  winStreak     Int                @default(0)
  fdShields     Int                @default(0)
  fatalCounters Int                @default(0)
  bets          Bet[]
  purchases     Purchase[]
  robbieHexes   RobbieHex[]
  megaphones    MegaphoneMessage[]
  lastWelfareAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  item      String
  cost      Int
  details   String?
  status    String   @default("PENDING")
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Tournament {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("GROUP_STAGE")
  matches   Match[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id                String      @id @default(cuid())
  playerA           String
  playerB           String
  charA             String?
  charB             String?
  status            String      @default("OPEN")
  winner            String?
  tournamentId      String?
  tournament        Tournament? @relation(fields: [tournamentId], references: [id])
  stageType         String?
  groupId           String?
  roundName         String?
  nextWinnerMatchId String?
  nextLoserMatchId  String?
  poolInjectA       Int         @default(0)
  poolInjectB       Int         @default(0)
  bettingClosesAt   DateTime?
  scoreA            Int?
  scoreB            Int?
  bets              Bet[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Bet {
  id               String   @id @default(cuid())
  userId           String
  matchId          String
  amount           Int
  choice           String
  comment          String?
  usedFdShield     Boolean  @default(false)
  usedFatalCounter Boolean  @default(false)
  predictedScoreA  Int?
  predictedScoreB  Int?
  user             User     @relation(fields: [userId], references: [id])
  match            Match    @relation(fields: [matchId], references: [id])
  createdAt        DateTime @default(now())
}

model RobbieHex {
  id          String   @id @default(cuid())
  playerName  String
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

model MegaphoneMessage {
  id        String   @id @default(cuid())
  userId    String
  message   String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  used      Boolean  @default(false)
  usedBy    String?
  createdAt DateTime @default(now())
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String
  details   String
  createdAt DateTime @default(now())
}
